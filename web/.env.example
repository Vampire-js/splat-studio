# Base URL of the FastAPI worker. Server-side only — the browser never calls
# the worker directly; all access goes through Next.js API routes.
WORKER_BASE_URL=http://localhost:8000

# Public base URL of THIS Next.js app — used to render the embed snippet
# (`<iframe src="${PUBLIC_BASE_URL}/embed/:jobId">`). Set to your prod URL.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

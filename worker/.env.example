# Local filesystem root where job artifacts are persisted.
# Override per-deploy. In v0 this is a stub for what will become S3 (or similar).
STORAGE_ROOT=./_storage

# Path to the bundled sample splat returned by the stubbed pipeline.
SAMPLE_SPLAT_PATH=./samples/sample.splat

# How long the stub "training" sleeps before flipping the job to `done`.
# Only used when the real pipeline is unavailable.
STUB_PROCESSING_SECONDS=4

# Host/port for the FastAPI server.
HOST=0.0.0.0
PORT=8000

# --- Real pipeline tunables ---------------------------------------------------
# Path to the brush binary. Defaults to worker/bin/brush (run scripts/install-brush.sh).
# BRUSH_BIN=/usr/local/bin/brush

# Downscale uploaded images to this max long edge before SfM.
PIPELINE_MAX_IMAGE_EDGE=1280

# brush training steps. 30k = paper-quality (slow); 7k = good v0 quality (~5-15 min on a 6GB GPU).
PIPELINE_TRAIN_STEPS=7000

# Upper bound on splat count. Caps VRAM and final file size.
PIPELINE_MAX_SPLATS=300000

# Spherical harmonics degree. 0=flat color, 1=basic view-dependent, 2=better reflections, 3=paper default.
PIPELINE_SH_DEGREE=2

# Max image resolution brush will use during training.
PIPELINE_TRAIN_MAX_RES=1280

# Delete uploads/ and intermediate COLMAP artifacts once scene.splat is produced.
# Set to 0 to keep them for debugging.
PIPELINE_CLEANUP=1

# wgpu backend brush uses. VULKAN works on Linux + most laptops.
# Alternatives: METAL (macOS), DX12 (Windows), GL (fallback).
WGPU_BACKEND=VULKAN
